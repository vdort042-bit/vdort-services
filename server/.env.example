PORT=5000
NODE_ENV=development

# JWT secret — use a long random string in production
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Frontend URL(s) for CORS — comma-separated for multiple domains
# Example: https://vdort-services.vercel.app,https://www.yourdomain.com
CLIENT_URL=http://localhost:5173

# Optional extra CORS origins (comma-separated)
# ALLOWED_ORIGINS=https://vdort-services.vercel.app

# Email — resume submissions sent to your inbox
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=vdort042@gmail.com
SMTP_PASS=your-gmail-app-password-here
ADMIN_EMAIL=vdort042@gmail.com

# Firebase Admin SDK credentials
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
# Firebase Storage bucket (resumes stored here in production)
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
